# ── LLM (FREE) ────────────────────────────────────────────────────────────────
# Get free key at: https://console.groq.com → API Keys → Create API Key
GROQ_API_KEY=

# ── Maps (FREE) ────────────────────────────────────────────────────────────────
# Get free token at: https://account.mapbox.com → copy Default public token
MAPBOX_TOKEN=

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://roadwatch:roadwatch123@localhost:5432/roadwatch
REDIS_URL=redis://localhost:6379

# ── App ────────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-any-random-string
ENVIRONMENT=development

# ── Optional (leave blank if not using OpenAI) ─────────────────────────────────
OPENAI_API_KEY=

# ── Frontend (set on Render after deploying backend) ──────────────────────────
VITE_API_URL=https://your-backend.onrender.com
VITE_MAPBOX_TOKEN=
